# --- LLM Curation ---
GEMINI_API_KEY=your-gemini-api-key

# --- Email (legacy SMTP - will be replaced by Buttondown) ---
GMAIL_ADDRESS=yourgmailaddress@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
NEWSLETTER_RECIPIENT=whoever-you-want-to-send-to@example.com

# --- Buttondown Newsletter ---
BUTTONDOWN_API_KEY=your-buttondown-api-key
BUTTONDOWN_USERNAME=your-buttondown-username

# --- Instagram auto-posting (Instagram API with Instagram Login) ---
# Long-lived (60-day) Instagram User access token. See INSTAGRAM_SETUP.md.
INSTAGRAM_ACCESS_TOKEN=your-long-lived-instagram-token
# Instagram user id: GET https://graph.instagram.com/v25.0/me?fields=user_id,username&access_token=TOKEN
INSTAGRAM_ACCOUNT_ID=178414xxxxxxxxxxx
# Optional — Graph API version (defaults to v25.0 if unset)
# INSTAGRAM_API_VERSION=v25.0